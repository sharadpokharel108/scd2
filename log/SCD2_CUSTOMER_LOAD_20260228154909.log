-- Step 1: Close old records if attributes changed
UPDATE TARGET.TGT_D_CUSTOMER_SCD2 AS tgt
SET
    END_DATE = CURRENT_DATE - 1,
    CURRENT_FLAG = FALSE
FROM TEMP.TMP_D_CUSTOMER AS tmp
WHERE tgt.CUSTOMER_ID = tmp.CUSTOMER_ID
AND tgt.CURRENT_FLAG = TRUE
AND (
    tgt.CUSTOMER_NAME <> tmp.CUSTOMER_NAME OR
    tgt.SEGMENT <> tmp.SEGMENT
);

-- Step 2: Insert new records
INSERT INTO TARGET.TGT_D_CUSTOMER_SCD2 (
    CUSTOMER_ID, CUSTOMER_NAME, SEGMENT, START_DATE, END_DATE, CURRENT_FLAG
)
SELECT
    tmp.CUSTOMER_ID,
    tmp.CUSTOMER_NAME,
    tmp.SEGMENT,
    CURRENT_DATE AS START_DATE,
    NULL AS END_DATE,
    TRUE AS CURRENT_FLAG
FROM TEMP.TMP_D_CUSTOMER AS tmp
LEFT JOIN TARGET.TGT_D_CUSTOMER_SCD2 AS tgt
ON tmp.CUSTOMER_ID = tgt.CUSTOMER_ID
WHERE tgt.CUSTOMER_KEY IS NULL
   OR tgt.CURRENT_FLAG = FALSE;


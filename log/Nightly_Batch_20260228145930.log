CREATE OR REPLACE VIEW STAGE.STG_F_SALES AS
SELECT
    ORDER_ID,
    CUSTOMER_ID,
    PRODUCT_ID,
    COUNTRY,
    REGION,
    STATE,
    CITY,
    POSTAL_CODE,
    ORDER_DATE,
    SHIP_DATE,
    SHIP_MODE,
    QUANTITY,
    DISCOUNT,
    SALES AS REVENUE,
    PROFIT,
    (SALES - PROFIT) AS COST
FROM LANDING.SALES;

